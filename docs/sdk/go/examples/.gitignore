# Local override pointing at a private (non-default) HydrAIDE instance.
# Never commit. See .env.example for the schema.
.env.local

# TLS material generated by `docker compose up` (hydraide-init service).
# Regenerated on demand; nothing here belongs in version control.
certificate/

# Go build artifacts. The named binaries get dropped here when someone
# runs `go build` from the examples root instead of from a recipe dir.
*.test
*.out
/01-quickstart/01-quickstart
/02-recipes/*/atomic-counter
/02-recipes/*/atomic-patch
/02-recipes/*/advanced-filters
/02-recipes/*/business-lock
/02-recipes/*/catalog-list
/02-recipes/*/live-subscribe
/02-recipes/*/profile-per-user
/02-recipes/*/ttl-queue
/03-reference-apps/*/todo-api
/03-reference-apps/*/url-shortener
/03-reference-apps/*/multi-tenant-saas
/atomic-counter
/atomic-patch
/advanced-filters
/business-lock
/catalog-list
/live-subscribe
/profile-per-user
/ttl-queue
/todo-api
/url-shortener
/multi-tenant-saas
