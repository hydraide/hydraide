# .env.example — defaults for the in-tree HydrAIDE instance brought up by
# `docker compose up -d`. Copy to .env.local to point at a different
# instance (a unit-test HydrAIDE on the network, for example). The Makefile
# loads .env.local if present, otherwise these defaults are used.
#
# Never commit .env.local. It is in .gitignore.

# gRPC endpoint of the HydrAIDE server.
HYDRA_HOST=localhost:5980

# Directory containing ca.crt, client.crt, client.key.
# Leave unset for in-tree examples — the setup helper auto-discovers the
# `certificate/` directory by walking upward from the recipe folder.
# Set this in .env.local when targeting a remote unit-test instance.
# HYDRA_CERT=/absolute/path/to/certificate

# Set to "true" to log gRPC connection diagnostics on startup.
HYDRA_CONNECTION_ANALYSIS=false
