# ---- IDE & Editor ignores ----
# JetBrains (IntelliJ, GoLand, WebStorm, etc.)
.idea/
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf
.idea/**/dataSources/
.idea/**/dataSources.local.xml
.idea/**/uiDesigner.xml
.idea/**/dbnavigator.xml
.idea/replstate.xml
.idea/sonarlint/
.idea/httpRequests
.idea/caches/

# Visual Studio Code
.vscode/
.vscode/*

# CMake build artifacts
cmake-build-*/

# ---- Go-specific ignores ----
# Go build cache and compiled binaries
/bin/
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Go modules
go.work
go.work.sum

# ---- Dependency directories ----
vendor/

# ---- Environment files ----
.env

# Locally-generated mTLS certificates for e2e tests
# (regenerate via scripts/generate-test-certs.sh)
sdk/go/hydraidego/testdata/certs/

db/
fallback.log
.github/copilot-instructions.md
app/core/hydra/data/*/**
app/core/hydra/swamp/data/*/**
sdk/go/hydraidego/data/*/**
app/core/hydra/settings/*/**
app/core/zeus/settings/*/**
sdk/go/hydraidego/settings/*/**
*/**/settings.json
app/server/e2etests/data/

# Claude Code — ship the public skill and CLAUDE.md, keep per-developer config private.
# Re-include .claude/ here to override the global ~/.config/git/ignore that
# excludes the whole directory; then selectively hide developer-specific files.
!.claude/
.claude/settings.json
.claude/settings.local.json

# Local planning docs (not for git)
plan/
plan/VECTOR_SEARCH_PLAN.md
plan/EMBEDDING_SIMILARITY_SEARCH_TERV.md
plan/EXPLORER_FIX_PLAN.md

# Build artifacts
/server
